{
  "name": "cepik-api-client",
  "version": "0.3.1",
  "description": "A modern TypeScript/JavaScript library for retrieving data from the public API of the Polish National Vehicles Database (CEPIK).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "coverage": "jest --coverage",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miqel-dll/cepik-client.git"
  },
  "keywords": [
    "cepik",
    "api",
    "cepik library",
    "wrapper",
    "api-wrapper",
    "cepik-api-wrapper",
    "cars api",
    "cars-data",
    "library",
    "libs",
    "cepik-library"
  ],
  "author": "miqel-dll",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "homepage": "https://github.com/miqel-dll/cepik-client#readme",
  "bugs": {
    "url": "https://github.com/miqel-dll/cepik-client/issues"
  },
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/src/**/*.spec.ts"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}